# Jira Configuration
JIRA_BASE_URL=https://hellofresh.atlassian.net
JIRA_EMAIL=your.email@hellofresh.com
JIRA_API_TOKEN=your_jira_api_token_here

# Epic Configuration  
EPIC_KEY=REW-323
PROJECT_KEY=REW

# Anthropic AI Configuration (Optional - like Agento)
# Get your API key from: https://console.anthropic.com/
# If not provided, AI features will use rule-based fallback

# Option 1: Claude CLI (Recommended - Uses Company AWS via SSO)
#   - If you have Claude CLI installed, it will be auto-detected
#   - Check by running: which claude
#   - No API key needed! Uses company's AWS Bedrock
# Option 2: Personal Anthropic API (Backup)
#   - Uncomment and set ANTHROPIC_API_KEY below
# Priority: Claude CLI > Anthropic API > Rule-based fallback
#ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Slack Webhook (Optional)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Server Configuration
PORT=5000
